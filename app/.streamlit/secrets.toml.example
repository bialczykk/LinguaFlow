# Example secrets for local or Streamlit Community Cloud.
#
# Local: copy this file to secrets.toml in this directory:
#   cp app/.streamlit/secrets.toml.example app/.streamlit/secrets.toml
#
# Cloud: paste the same TOML (without comments if you prefer) in:
#   Your app → Settings → Secrets
#
# Use flat keys matching your root .env. Typical keys:

ANTHROPIC_API_KEY = "paste-your-anthropic-key-here"

# Optional — LangSmith tracing
# LANGCHAIN_TRACING_V2 = "true"
# LANGSMITH_API_KEY = "paste-langsmith-key-if-used"
# LANGSMITH_PROJECT = "linguaflow-lab"
